{
  "manifest_version":3,
  "version":"1.1",
  "name":"thinkle",
  "description": "A browser extension that enables ChatGPT's Thinking mode instantly with a keyboard shortcut -no clicking required",
  "permissions": ["storage"],
  "icons": {
    "16": "thinkle16.png",
    "32": "thinkle32.png",
    "48": "thinkle48.png",
    "128": "thinkle128.png"
  },
  "action":{
  "default_icon": {
    "16": "thinkle16.png",
    "32": "thinkle32.png",
    "48": "thinkle48.png",
    "128": "thinkle128.png"
  }, 
    "default_title": "Click me!",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "main.js"
  },
  "commands": {
    "open-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+X"
      },
      "description": "Open popup"
    }
  },
  "web_accessible_resources": [{
  "resources": ["ex.js"],
  "matches": ["https://chatgpt.com/*"]
}]
}






